{
  "name": "playwright_sparkers_lms",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "sriram": "cucumber-js --tags @sriram",
    "submodule": "cucumber-js --tags @submodule",
    "Jothika": "cucumber-js --tags @Jothika",
    "Harini": "cucumber-js --tags \"@ServiceManagement or @mandatoryempty\"",
    "jagadeep": "cucumber-js --tags \"@jagadeep and not @Bug-1\"",
    "Subha": "cucumber-js --tags   @Subha",
    "parallel": "cucumber-js --parallel 2",
    "re:fail": "cucumber-js -p rerun",
    "posttest": "npx ts-node src/test/utils/report.ts",
    "test:qa": "cross-env TEST_ENV=qa cucumber-js",
    "print": "cucumber-js --tags @print",
    "module": "cucumber-js --tags @module",
    "Duplicate": "cucumber-js --tags @Duplicate",
    "preview": "cucumber-js --tags @preview",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure": "npm test && npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "allure-commandline": "^2.43.0",
    "allure-cucumberjs": "^3.10.2",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "typescript": "^6.0.3",
    "winston": "^3.19.0"
  }
}
